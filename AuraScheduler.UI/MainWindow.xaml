<Window
    x:Class="AuraScheduler.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:AuraScheduler.UI"
    mc:Ignorable="d"
    Title="AURA Scheduler">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <local:BoolNegationConverter x:Key="boolNegationConverter"/>
            <local:BoolToVisibilityConverter x:Key="boolToVisibilityConverter"/>
            <local:EnumToStringConverter x:Key="enumToStringConverter"/>
        </Grid.Resources>

        <NavigationView x:Name="NavView"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        OpenPaneLength="200"
                        CompactPaneLength="48"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="DashboardItem" Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsItem" Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
            <!-- ═══════════ DASHBOARD PANEL ═══════════ -->
            <Grid x:Name="DashboardPanel" Padding="28,20,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Status cards -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">

                    <!-- Mode card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20,16" MinWidth="170">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE781;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="Mode"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SettingsViewModel.Mode, Converter={StaticResource enumToStringConverter}}"
                                       Style="{ThemeResource TitleTextBlockStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Schedule card (only shown when schedule mode active) -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20,16" MinWidth="260"
                            Visibility="{Binding SettingsViewModel.ScheduleEnabled, Converter={StaticResource boolToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE917;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="Schedule"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="ON"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SettingsViewModel.ScheduleLightsOn}"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Rectangle Grid.Column="1"
                                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                           Width="1" Margin="0,4"/>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="OFF"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SettingsViewModel.ScheduleLightsOff}"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Activity log card -->
                <Border Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid Padding="20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Activity Log"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        </StackPanel>

                        <ListView Grid.Row="1"
                                  x:Name="LogListBox"
                                  ItemsSource="{Binding LogEntries}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════ SETTINGS PANEL ═══════════ -->
            <Grid x:Name="SettingsPanel" Visibility="Collapsed" Padding="28,20,28,28">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="420" HorizontalAlignment="Left" Spacing="16">

                        <!-- Mode selector -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="20,16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE781;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Light Mode"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                </StackPanel>
                                <ComboBox MinWidth="280"
                                          ItemsSource="{Binding SettingsViewModel.LightModes}"
                                          SelectedItem="{Binding SettingsViewModel.Mode, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource enumToStringConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Schedule card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="20,16"
                                Visibility="{Binding SettingsViewModel.ScheduleEnabled, Converter={StaticResource boolToVisibilityConverter}}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE917;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Schedule"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                </StackPanel>
                                <TimePicker Header="Lights On" MinWidth="280"
                                            SelectedTime="{Binding SettingsViewModel.ScheduleLightsOnTimeSpan, Mode=TwoWay}"/>
                                <TimePicker Header="Lights Off" MinWidth="280"
                                            SelectedTime="{Binding SettingsViewModel.ScheduleLightsOffTimeSpan, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <!-- Window behavior card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="20,16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7E8;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Window Behavior"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                </StackPanel>
                                <ToggleSwitch Header="Minimize to tray on close"
                                              IsOn="{Binding SettingsViewModel.CloseToTray, Mode=TwoWay}"
                                              OnContent="On" OffContent="Off"/>
                                <ToggleSwitch Header="Start minimized"
                                              IsOn="{Binding SettingsViewModel.StartMinimized, Mode=TwoWay}"
                                              OnContent="On" OffContent="Off"/>
                            </StackPanel>
                        </Border>

                        <!-- Save / Cancel -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    Visibility="{Binding SettingsViewModel.IsDirty, Converter={StaticResource boolToVisibilityConverter}}">
                            <Button Content="Save Changes"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    MinWidth="130"
                                    Command="{Binding SettingsViewModel.SaveChangesCommand}"/>
                            <Button Content="Discard"
                                    MinWidth="100"
                                    Command="{Binding SettingsViewModel.CancelChangesCommand}"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Rectangle Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Height="1"/>

                        <!-- Exit application -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Exit Application"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Close the app and remove the tray icon."
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Button Content="Exit"
                                    Margin="0,8,0,0"
                                    MinWidth="100"
                                    Click="ExitButton_Click">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonForeground"
                                                     Color="{ThemeResource SystemErrorTextColor}"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                     Color="{ThemeResource SystemErrorTextColor}"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                     Color="{ThemeResource SystemErrorTextColor}"/>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            </Grid><!-- end wrapper -->
        </NavigationView>

        <!-- Custom title bar drag region — rendered over the nav pane header area -->
        <!-- Margin left = CompactPaneLength (48) to avoid overlapping the hamburger button -->
        <Grid x:Name="AppTitleBar"
              Height="48"
              VerticalAlignment="Top"
              HorizontalAlignment="Stretch"
              Margin="48,0,0,0"
              Background="Transparent">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                <Image x:Name="TitleBarIcon"
                       Width="16" Height="16"
                       VerticalAlignment="Center"/>
                <TextBlock Text="AURA Scheduler"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
